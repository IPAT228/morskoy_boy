# Скопируйте в .env и заполните строку подключения из Neon / Supabase / Vercel Postgres.
# Те же переменные добавьте в Vercel → Settings → Environment Variables.

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Необязательно (на Vercel рекомендуется задать свой SECRET_KEY):
# SECRET_KEY=your-long-random-secret

# Админ создаётся автоматически при первом запуске (только если ещё нет):
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin
# ADMIN_EMAIL=admin@example.com
